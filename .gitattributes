# Normalizar saltos de línea: LF en el repo, conversión automática según OS al checkout
* text=auto

# Forzar LF para archivos de código y config (importante para Docker/Linux)
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
.gitignore  text eol=lf

# Binarios: no tocar
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
