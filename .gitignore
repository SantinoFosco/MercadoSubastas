#   PYTHON / FASTAPI (APIMercadoSubastas)
# ==========================================
APIMercadoSubastas/venv/
APIMercadoSubastas/.venv/
APIMercadoSubastas/.env
APIMercadoSubastas/*.egg-info/
APIMercadoSubastas/dist/
