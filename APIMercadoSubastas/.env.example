# Base de datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/mercado_subastas

# Gmail — usar una App Password (no la contraseña real de la cuenta)
# Guía: https://support.google.com/accounts/answer/185833
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# URL base para los links de pago en los emails (puede ser un dominio falso para el TPO)
APP_BASE_URL=https://pay.mercadosubastas.com

# Habilita los endpoints destructivos /dev/reset/* — NUNCA poner true en producción
DEV_MODE=false
