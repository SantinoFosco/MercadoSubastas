      "name": "Auth y Registro",
      "item": [
        {
          "name": "Iniciar Registro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/registro/iniciar" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"documento\": \"12345678\",\n  \"mail\": \"juan.perez@mail.com\",\n  \"direccion\": \"Av. Corrientes 1234, CABA\",\n  \"pais\": 1\n}"
            }
          }
        }
      ]
    },
